{
  "name": "neon-protocol-ide",
  "version": "1.0.0",
  "description": "Neon Protocol IDE - Agentic Architectural Blueprint IDE",
  "main": "index.js",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3001 && electron .\"",
    "electron-build": "next build && electron-builder"
  },
  "keywords": [
    "IDE",
    "Agentic",
    "Architecture",
    "Blueprint",
    "ReactFlow",
    "Monaco"
  ],
  "author": "Neon Protocol Team",
  "license": "MIT",
  "dependencies": {
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.10.1",
    "@monaco-editor/react": "^4.6.0",
    "zustand": "^4.5.1",
    "lucide-react": "^0.344.0",
    "framer-motion": "^11.0.8",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  }
}
